{
  "name": "@slowpoison/irisbot",
  "version": "0.4.0",
  "description": "IrisBot — multi-provider Slack AI bot powered by Vercel AI SDK",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "bin": {
    "irisbot": "dist/index.js"
  },
  "files": [
    "dist",
    ".env.example"
  ],
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts --ext ts,json",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "publish": "pnpm publish --access public"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/openai-compatible": "^2.0.38",
    "@slack/bolt": "^4.6.0",
    "ai": "^6.0.146",
    "ai-sdk-ollama": "^3.8.2",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@slack/types": "^2.20.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
